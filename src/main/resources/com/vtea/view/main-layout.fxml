<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.vtea.controller.MainLayoutController"
            prefWidth="1280" prefHeight="800"
            styleClass="main-root">

    <!-- ===== TOP: Header ===== -->
    <top>
        <HBox styleClass="header" alignment="CENTER_LEFT" spacing="0">
            <padding><Insets top="0" right="24" bottom="0" left="24"/></padding>

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="14">
                <StackPane styleClass="header-logo-box" minWidth="48" minHeight="48">
                    <Label text="☕" style="-fx-font-size: 22px;"/>
                </StackPane>
                <VBox spacing="0">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="VTea" styleClass="header-brand"/>
                        <Circle radius="3" styleClass="header-dot"/>
                        <Label text="Cafe &amp; Trà Sữa" styleClass="header-sub"/>
                    </HBox>
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Circle radius="4" styleClass="online-dot"/>
                        <Label text="Hệ thống đang hoạt động" styleClass="header-status"/>
                    </HBox>
                </VBox>
            </HBox>

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- User Info -->
            <HBox styleClass="user-info-box" alignment="CENTER_LEFT" spacing="10">
                <StackPane styleClass="user-avatar">
                    <Label fx:id="userInitialLabel" text="A" styleClass="user-avatar-text"/>
                </StackPane>
                <VBox spacing="0">
                    <Label fx:id="userNameLabel" text="Admin" styleClass="user-name"/>
                    <Label fx:id="userRoleLabel" text="Quản lý" styleClass="user-role"/>
                </VBox>
            </HBox>

            <!-- Logout Button -->
            <Button text="⏻  Đăng xuất"
                    styleClass="btn-logout"
                    onAction="#handleLogout">
                <HBox.margin><Insets left="16"/></HBox.margin>
            </Button>

        </HBox>
    </top>

    <!-- ===== LEFT: Sidebar ===== -->
    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="4">
            <padding><Insets top="20" right="12" bottom="20" left="12"/></padding>

            <Label text="MENU CHÍNH" styleClass="sidebar-section-title">
                <VBox.margin><Insets bottom="8" left="8"/></VBox.margin>
            </Label>

            <Button fx:id="btnDashboard"
                    text="📊  Dashboard"
                    styleClass="nav-btn"
                    maxWidth="Infinity"
                    onAction="#handleDashboard"/>

            <Button fx:id="btnPOS"
                    text="🛒  Bán hàng (POS)"
                    styleClass="nav-btn"
                    maxWidth="Infinity"
                    onAction="#handlePOS"/>

        </VBox>
    </left>

    <!-- ===== CENTER: Content Area ===== -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
        </StackPane>
    </center>

</BorderPane>
