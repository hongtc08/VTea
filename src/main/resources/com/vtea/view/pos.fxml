<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.vtea.controller.POSController"
      spacing="20" styleClass="screen-root">

    <!-- ===== LEFT: Products Panel ===== -->
    <VBox HBox.hgrow="ALWAYS" spacing="14">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="Bán hàng (POS)" styleClass="screen-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <StackPane styleClass="cart-badge">
                <Label fx:id="cartCountLabel" text="0" styleClass="cart-badge-text"/>
            </StackPane>
        </HBox>

        <!-- Search -->
        <TextField fx:id="searchField"
                   promptText="🔍  Tìm kiếm sản phẩm..."
                   styleClass="input-field"/>

        <!-- Category Filter -->
        <ScrollPane hbarPolicy="NEVER" vbarPolicy="NEVER" fitToHeight="true"
                    styleClass="category-scroll">
            <HBox fx:id="categoryBar" spacing="8" alignment="CENTER_LEFT">
                <padding><Insets top="4" bottom="4"/></padding>
            </HBox>
        </ScrollPane>

        <!-- Products Grid (scrollable) -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="products-scroll">
            <FlowPane fx:id="productGrid"
                      hgap="14" vgap="14"
                      prefWrapLength="800"/>
        </ScrollPane>

    </VBox>

    <!-- ===== RIGHT: Cart Panel ===== -->
    <VBox styleClass="cart-panel" prefWidth="380" minWidth="340" spacing="0">

        <!-- Cart Header -->
        <HBox styleClass="cart-header" alignment="CENTER_LEFT" spacing="0">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
            <Label text="Đơn hàng" styleClass="cart-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Xóa tất cả"
                    styleClass="btn-clear-cart"
                    onAction="#handleClearCart"/>
        </HBox>

        <!-- Cart Items (scrollable) -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="cart-scroll">
            <VBox fx:id="cartItemsBox" spacing="8">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

                <!-- Empty state -->
                <Label fx:id="cartEmptyLabel"
                       text="🛒\n\nChưa có sản phẩm nào"
                       styleClass="cart-empty"
                       maxWidth="Infinity"
                       alignment="CENTER"
                       textAlignment="CENTER"
                       wrapText="true"/>
            </VBox>
        </ScrollPane>

        <!-- Checkout Section -->
        <VBox fx:id="checkoutSection" styleClass="checkout-section" spacing="10">
            <padding><Insets top="16" right="20" bottom="20" left="20"/></padding>

            <HBox>
                <Label text="Tạm tính:" styleClass="checkout-row-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="subtotalLabel" text="0₫" styleClass="checkout-row-value"/>
            </HBox>
            <HBox>
                <Label text="VAT (10%):" styleClass="checkout-row-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="taxLabel" text="0₫" styleClass="checkout-row-value"/>
            </HBox>
            <Separator/>
            <HBox>
                <Label text="Tổng cộng:" styleClass="checkout-total-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="totalLabel" text="0₫" styleClass="checkout-total-value"/>
            </HBox>

            <Button text="💳  Thanh toán"
                    styleClass="btn-primary"
                    maxWidth="Infinity"
                    onAction="#handleCheckout">
                <VBox.margin><Insets top="8"/></VBox.margin>
            </Button>
        </VBox>

    </VBox>

</HBox>
